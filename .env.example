# ============================================================
# AI Email Reading Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# NEVER commit .env with real secrets to version control!
# This project uses hybrid storage: Supabase (cloud) + SQLite (local fallback)

# ============================================================
# OPTIONAL: Supabase Configuration (Cloud Storage)
# ============================================================
# If not provided, the system falls back to SQLite local storage
# Get from: https://supabase.com → Project Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend server also needs Supabase config
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ============================================================
# OPTIONAL: AI Provider Configuration
# ============================================================
# If not provided, falls back to rule-based classification
# Get from: https://console.anthropic.com

ANTHROPIC_API_KEY=

# Alternative AI providers (Claude is currently implemented)
# Future support: OpenAI, Gemini, local Ollama
# OPENAI_API_KEY=sk-your-openai-key
# GEMINI_API_KEY=your-gemini-key

# ============================================================
# Email Source Configuration
# ============================================================
# Options:
#   mock — Use 20 curated sample emails (great for testing)
#   imap — Connect to real Gmail/IMAP account
# Default: mock

EMAIL_MODE=mock

# ============================================================
# IMAP Configuration (only needed if EMAIL_MODE=imap)
# ============================================================
# For Gmail: enable "App Passwords" in Google Account settings
# https://myaccount.google.com/apppasswords

IMAP_HOST=imap.gmail.com
IMAP_USER=your-email@gmail.com
IMAP_PASSWORD=your-app-password
IMAP_PORT=993

# ============================================================
# Agent Scheduling Configuration
# ============================================================
# How often the agent polls for new emails (milliseconds)
# Default: 120000 (2 minutes)
# Examples:
#   60000 = 1 minute (more frequent, higher CPU)
#   300000 = 5 minutes (less frequent, lower load)

POLL_INTERVAL_MS=120000

# Backend agent server port
AGENT_PORT=3001

# Frontend agent URL (for dashboard manual triggers)
VITE_AGENT_URL=http://localhost:3001

# ============================================================
# Docker/Production Configuration (optional)
# ============================================================
# NODE_ENV=production
# LOG_LEVEL=info
